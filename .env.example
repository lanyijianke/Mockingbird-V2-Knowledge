# ──────────────────────────────────────────────────
# Mockingbird Knowledge Web - Environment Variables
# Copy this file to .env.local and fill in real values.
# ──────────────────────────────────────────────────

# ── 站点基础 ──

# 站点绝对地址，用于 canonical / robots / sitemap / JSON-LD / OG
SITE_URL=http://localhost:5046

# ── 数据库 ──

# 本地 SQLite 数据库路径
SQLITE_DB_PATH=./data/knowledge.db

# ── 文章内容源 ──

# 本地文章源配置（JSON 数组）
# 示例见 README.md 第 3 节
ARTICLE_LOCAL_SOURCES=

# ── 提示词内容 ──

# 提示词图片/视频下载后的本地媒体目录
CONTENT_PROMPTS_MEDIA_DIR=./public/content/prompts/media

# 提示词同步的 GitHub 仓库源（JSON 数组，可选）
PROMPT_SYNC_REPOS=

# 提示词源配置目录（可选，有默认值）
# PROMPT_SOURCE_CONFIG_DIR=

# ── 管理接口鉴权 ──

# 管理接口鉴权 token（优先使用此变量）
KNOWLEDGE_ADMIN_TOKEN=

# 管理接口鉴权 token（兼容回退）
ADMIN_API_TOKEN=

# ── 调度器 ──

# 提示词同步 cron 表达式
JOB_PROMPT_SYNC_CRON=30 */1 * * * *

# 排行榜同步 cron 表达式
JOB_RANKING_SYNC_CRON=0 */2 * * *

# ── SEO ──

# 是否允许搜索引擎索引（true/false）
SEO_CAN_INDEX=false

# 是否屏蔽 Baidu 爬虫（true/false）
ROBOTS_BLOCK_BAIDU=false

# Sitemap 分片大小（可选，有默认值）
# SITEMAP_CHUNK_SIZE=1000

# ── 安全 ──

# 媒体下载最大字节数（SSRF/资源防护）
MEDIA_DOWNLOAD_MAX_BYTES=52428800

# ── 排行榜抓取（可选） ──

# Product Hunt API 密钥（热榜抓取用）
# PRODUCTHUNT_API_KEY=

# Product Hunt API Secret
# PRODUCTHUNT_API_SECRET=

# ── 日志 ──

# 日志级别：debug / info / warn / error
# LOG_LEVEL=info
